                {
                  "id": "about-page-text",
                  "type": "text",
                  "props": {
                    "html": "<p>PageKit started as an internal tool for shipping client sites without touching code for every copy change. It grew into a content-first template system: edit <strong>everything</strong> — text, images, theme, layout — through JSON and Markdown, and let the renderer do the rest.</p><p>We believe the fastest way to launch a site is to separate <em>content</em> from <em>code</em> completely.</p>"
                  },
                  "children": []
